{
  "entities": {
    "Project": {
      "title": "Project",
      "description": "A bidding project",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "title": { "type": "string" },
        "agency": { "type": "string" },
        "location": { "type": "string" },
        "budget": { "type": "string" },
        "deadline": { "type": "string" },
        "status": { "type": "string", "enum": ["待评审", "评审中", "已评审", "标书编写中", "已完成", "已放弃"] },
        "publishDate": { "type": "string" },
        "source": { "type": "string" },
        "hasReview": { "type": "boolean" },
        "hasDraft": { "type": "boolean" },
        "uid": { "type": "string", "description": "Owner UID" }
      },
      "required": ["title", "agency", "status", "uid"]
    },
    "Qualification": {
      "title": "Qualification",
      "description": "Company qualification or certification",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "code": { "type": "string" },
        "expiry": { "type": "string" },
        "status": { "type": "string" },
        "type": { "type": "string" },
        "uid": { "type": "string" }
      },
      "required": ["title", "code", "expiry", "status", "type", "uid"]
    },
    "Personnel": {
      "title": "Personnel",
      "description": "Company personnel and their certificates",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "role": { "type": "string" },
        "certificates": { "type": "array", "items": { "type": "string" } },
        "status": { "type": "string" },
        "uid": { "type": "string" }
      },
      "required": ["name", "role", "uid"]
    },
    "Performance": {
      "title": "Performance",
      "description": "Company performance and project cases",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "client": { "type": "string" },
        "amount": { "type": "string" },
        "date": { "type": "string" },
        "type": { "type": "string" },
        "uid": { "type": "string" }
      },
      "required": ["title", "client", "amount", "date", "uid"]
    },
    "Standard": {
      "title": "Standard",
      "description": "Industry standards and regulations",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "code": { "type": "string" },
        "category": { "type": "string" },
        "uid": { "type": "string" }
      },
      "required": ["title", "code", "category", "uid"]
    },
    "User": {
      "title": "User",
      "description": "User profile",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "email": { "type": "string" },
        "displayName": { "type": "string" },
        "photoURL": { "type": "string" },
        "role": { "type": "string", "enum": ["admin", "user"] }
      },
      "required": ["uid", "email", "role"]
    }
  },
  "firestore": {
    "/projects/{projectId}": {
      "schema": "Project",
      "description": "Bidding projects"
    },
    "/qualifications/{qualificationId}": {
      "schema": "Qualification",
      "description": "Company qualifications"
    },
    "/personnel/{personnelId}": {
      "schema": "Personnel",
      "description": "Company personnel"
    },
    "/performances/{performanceId}": {
      "schema": "Performance",
      "description": "Company performances"
    },
    "/standards/{standardId}": {
      "schema": "Standard",
      "description": "Industry standards"
    },
    "/users/{userId}": {
      "schema": "User",
      "description": "User profiles"
    }
  }
}
